@model ML.Captura
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    <div class="container">

        <div class="row">
            <div class="row">
                @Html.LabelFor(m => m.Id)
                @Html.TextBoxFor(m => m.Id)
            </div>
            <div class="row">
                @Html.LabelFor(m => m.Nombre)
                @Html.TextBoxFor(m => m.Nombre)

            </div>
            <div class="row">
                @Html.LabelFor(m => m.Paterno)
                @Html.TextBoxFor(m => m.Paterno)
            </div>
            <div class="row">
                @Html.LabelFor(m => m.Materno)
                @Html.TextBoxFor(m => m.Materno)
            </div>

            <div class="row">
      
            </div>

            <div class="col">
                @Html.ActionLink("Guardar","Add", "Home", new { id = Model.Id} , new{ @class="btn btn-success"})
            </div>
            <div class=" col">
                @Html.ActionLink("usuario GetAll", "UsuarioGetAll", "Home", new { id = Model.Id }, new { @class = "btn btn-success" })

            </div>

        </div>



    </div>




}
