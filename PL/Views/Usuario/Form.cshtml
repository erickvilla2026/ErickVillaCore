@model ML.Usuario



@using (Html.BeginForm("Form", "Usuario", FormMethod.Post, new { @enctype = "multipart/form-data" }))
{


    <div class="form-group">
        @Html.LabelFor(m => m.IdUsuario)
        @Html.TextBoxFor(m => m.IdUsuario, new { @class = "form-control" })
    </div>
    <div class="row">
        <div class="col-md-4 form-group ">
            @Html.LabelFor(m => m.Nombre)
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
        </div>

        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })

        <div class="col-md-4 form-group ">
            @Html.LabelFor(m => m.ApellidoPaterno)
            @Html.TextBoxFor(m => m.ApellidoPaterno, new { @class = "form-control" })
        </div>

        <div class="col-md-4 form-group ">
            @Html.LabelFor(m => m.ApellidoMaterno)
            @Html.TextBoxFor(m => m.ApellidoMaterno, new { @class = "form-control" })
        </div>
    </div>


    <div class="row">

        <div>
            @Html.Label("Correo electronico")
        </div>
        <div class="input-group mb-3">
            <!-- Assuming you are using Font Awesome for the fa-envelope icon -->
            <span class="input-group-text">
                <i class="bi bi-envelope-at"></i>
            </span>
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control input-field" })
        </div>


        <div class="col-md-4 form-group mb-3">
            @Html.LabelFor(m => m.Password)
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-lock"></i>
                </span>
                @Html.TextBoxFor(m => m.Password, new { @class = "form-control", type = "password" })
            </div>
        </div>

        <div class="col-md-4 form-group mb-3">
            @Html.LabelFor(m => m.UserName)
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-file-person"></i>
                </span>
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control" })
            </div>
        </div>
    </div>

    <div>
        <div class="col-md-4 mb-3">
            @Html.LabelFor(m => m.CURP)
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-file-earmark-post-fill"></i>
                </span>
                @Html.TextBoxFor(m => m.CURP, new { @class = "form-control", onblur = "ValidarCURP(this)" })
            </div>
        </div>


        <div class="col-md-4 form-group mb-3">
            @Html.LabelFor(m => m.FechaNacimiento)
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-calendar2-day"></i>
                </span>
                @Html.TextBoxFor(m => m.FechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            </div>
        </div>

        <div class="col-md-4 form-group mb-3">
            @Html.LabelFor(m => m.Sexo)
            @*Html.TextBoxFor(m => m.Sexo, new { @class = "form-control" })*@
            @*creacion de radivo boton*@
            <div class="col">
                @Html.RadioButtonFor(m => m.Sexo, "X ") Hombre
                @Html.RadioButtonFor(m => m.Sexo, "M ") Mujer
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 form-group mb-3">
            @Html.LabelFor(m => m.Telefono)
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-telephone-outbound"></i>
                </span>
                @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
            </div>
        </div>

        <div class="col-md-4 ">
            @Html.LabelFor(m => m.Celular)
            <div class="input-group mb-3">
                <span class="input-group-text">
                    <i class="bi bi-telephone"></i>
                </span>
                @Html.TextBoxFor(m => m.Celular, new { @class = "form-control" })
            </div>
        </div>
    </div>




    <div>
        @Html.LabelFor(m => m.Estatus)
        @*Html.TextBoxFor(m => m.Estatus, new { @class = "form-control" })*@
        <div class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="Estatus"
                   value="true"
            @(Model.Estatus == true ? "checked" : "") />
        </div>
    </div>

    if (Model.Direccion.Colonia.Municipio.Estado.Estados != null)
    {
        <div class=" py-3">
            @Html.DropDownListFor(m => m.Direccion.Colonia.Municipio.Estado.IdEstado, new SelectList(Model.Direccion.Colonia.Municipio.Estado.Estados
                    , "IdEstado", "Nombre"), "Estados", new { @class = "form-select", onchange = "EstadoGetByMunicipio()", @id = "ddlEstado" })
        </div>
    }
    else
    {
        <div>hola mundo</div>
    }
    if (Model.Direccion.Colonia.Municipio.Municipios != null)
    {
        <div class=" py-3">
            @Html.DropDownListFor(m => m.Direccion.Colonia.Municipio.IdMunicipio, new SelectList(Model.Direccion.Colonia.Municipio.Municipios
                    , "IdMunicipio", "Nombre"), "Municipio", new { @class = "form-select", onchange = "MunicipioGetByIdColonia()", @id = "ddlMunicipio" })
        </div>
    }
    else
    {
        <div class=" py-3">
            @Html.DropDownListFor(m => m.Direccion.Colonia.Municipio.IdMunicipio, new SelectList(String.Empty)
                    , "Municipio", new { @class = "form-select", onchange = "MunicipioGetByIdColonia()", @id = "ddlMunicipio" })
        </div>
    }



    <div class="py-3">
        @Html.LabelFor(m => m.Direccion.calle)
        @Html.TextBoxFor(m => m.Direccion.calle, new { @class = "form-control" })
    </div>

    <div class="py-3">
        @Html.LabelFor(m => m.Direccion.NumeroInterior)
        @Html.TextBoxFor(m => m.Direccion.NumeroInterior, new { @class = "form-control" })
    </div>

    <div class="py-3">
        @Html.LabelFor(m => m.Direccion.NumeroExterior)
        @Html.TextBoxFor(m => m.Direccion.NumeroExterior, new { @class = "form-control" })
    </div>


}

<script>
    function MunicipioGetByIdColonia()
        {
        var ddlEstado = $('#ddlEstado').val();
            console.log(ddlEstado);

        $.ajax({
            url: '@Url.Action("EstadoGetByIdMunicipio", "Home")?IdEstado='+ddlEstado,
            type: 'GET',
            success: function(){
                console.log("entro municipio")
            },
            error: function(){
                console.log("error municioi")
            }
        });
        }
</script>

<script>
    function EstadoGetByMunicipio() {
        var idEstado = document.getElementById("ddlEstado").value;
        console.log("Estado seleccionado:", idEstado);
    }
</script>












